{
  "name": "nestify-server",
  "version": "1.0.0",
  "description": "This is Nestify Real Estate Application Server",
  "keywords": [
    "node.js",
    "express.js",
    "postgrqSQL",
    "prisma",
    "orm",
    "real",
    "estate"
  ],
  "homepage": "https://github.com/MdShijanAli/nestify-server#readme",
  "bugs": {
    "url": "https://github.com/MdShijanAli/nestify-server/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MdShijanAli/nestify-server.git"
  },
  "license": "ISC",
  "author": "Md Shijan Ali",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "migrate": "npx prisma migrate dev",
    "generate": "npx prisma generate",
    "show:db": "npx prisma studio",
    "generate:auth": "npx @better-auth/cli generate",
    "seed:admin": "tsx src/script/seedAdmin.ts",
    "build": "prisma generate && tsc",
    "init:typescript": "npx tsc --init",
    "build:vercel": "prisma generate && tsup src/index.ts --format esm --platform node --target node20 --outDir api --external pg-native",
    "postinstall": "prisma generate",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "axios": "^1.15.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.9",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  }
}
